<Window x:Class="Transpiler.Desktop.Views.IdeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Transpiler.Desktop.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:IdeViewModel, IsDesignTimeCreatable=False}"
        Title="{Binding WindowTitle}"
        Width="1080"
        Height="720"
        MinWidth="820"
        MinHeight="520"
        WindowStartupLocation="CenterOwner">

  <Window.InputBindings>
    <KeyBinding Key="S" Modifiers="Control" Command="{Binding SaveCommand}" />
  </Window.InputBindings>

  <DockPanel>

    <!-- Menu -->
    <Menu DockPanel.Dock="Top">
      <MenuItem Header="_File">
        <MenuItem Header="Open _Folder…" Command="{Binding OpenFolderCommand}" />
        <MenuItem Header="Open _File…" Command="{Binding OpenFileCommand}" />
        <Separator />
        <MenuItem Header="_Save" Command="{Binding SaveCommand}" InputGestureText="Ctrl+S" />
        <MenuItem Header="Save _As…" Command="{Binding SaveAsCommand}" />
        <Separator />
        <MenuItem Header="_Close" Click="OnCloseClicked" />
      </MenuItem>
      <MenuItem Header="_View">
        <MenuItem Header="_Reload languages" Command="{Binding ReloadCommand}" />
      </MenuItem>
    </Menu>

    <!-- Status bar (VS Code-style strip along the very bottom) -->
    <Border DockPanel.Dock="Bottom" Background="#FF007ACC" Padding="10,3">
      <DockPanel LastChildFill="False">
        <TextBlock DockPanel.Dock="Left" Foreground="White" Text="{Binding StatusText}" />
        <TextBlock DockPanel.Dock="Right" Foreground="White" Text="{Binding Language}" />
        <TextBlock DockPanel.Dock="Right" Margin="0,0,16,0" Foreground="White" Text="{Binding FileLabel}" />
      </DockPanel>
    </Border>

    <!-- Working area: [explorer | code] over a full-width console -->
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="*" MinHeight="140" />
        <RowDefinition Height="4" />
        <RowDefinition Height="200" MinHeight="90" />
      </Grid.RowDefinitions>

      <!-- Explorer + code -->
      <Grid Grid.Row="0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="240" MinWidth="150" />
          <ColumnDefinition Width="4" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- File Explorer -->
        <DockPanel Grid.Column="0" Background="#FF252526">
          <TextBlock DockPanel.Dock="Top"
                     Margin="10,6"
                     Foreground="#FFBBBBBB"
                     FontWeight="SemiBold"
                     Text="EXPLORER" />
          <Grid>
            <TreeView x:Name="FileTree"
                      ItemsSource="{Binding Roots}"
                      Background="#FF252526"
                      Foreground="#FFCCCCCC"
                      BorderThickness="0"
                      MouseDoubleClick="OnFileTreeDoubleClick">
              <TreeView.ItemContainerStyle>
                <Style TargetType="TreeViewItem">
                  <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                  <Setter Property="Foreground" Value="#FFCCCCCC" />
                </Style>
              </TreeView.ItemContainerStyle>
              <TreeView.Resources>
                <HierarchicalDataTemplate DataType="{x:Type vm:FileNode}" ItemsSource="{Binding Children}">
                  <TextBlock Text="{Binding Name}" ToolTip="{Binding FullPath}" />
                </HierarchicalDataTemplate>
              </TreeView.Resources>
            </TreeView>

            <!-- Empty-state hint (shown until a folder is opened) -->
            <TextBlock Margin="12"
                       Foreground="#FF808080"
                       TextWrapping="Wrap"
                       IsHitTestVisible="False"
                       Text="Open a folder (File ▸ Open Folder…) to browse .cl / .clx files, then double-click one to edit it.">
              <TextBlock.Style>
                <Style TargetType="TextBlock">
                  <Setter Property="Visibility" Value="Collapsed" />
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding HasItems, ElementName=FileTree}" Value="False">
                      <Setter Property="Visibility" Value="Visible" />
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </TextBlock.Style>
            </TextBlock>
          </Grid>
        </DockPanel>

        <GridSplitter Grid.Column="1"
                      Width="4"
                      HorizontalAlignment="Stretch"
                      Background="#FF3F3F46"
                      ShowsPreview="True" />

        <!-- Code area: gutter + editor with indentation-guide overlay -->
        <Grid Grid.Column="2" Background="#FF1E1E1E">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>

          <!-- Line-number gutter (drawn in code-behind) -->
          <Border Grid.Column="0" Background="#FF1E1E1E">
            <Canvas x:Name="GutterCanvas" Width="52" ClipToBounds="True" />
          </Border>

          <!-- Editor + indentation guides (same cell, guides drawn on top in whitespace) -->
          <Grid Grid.Column="1">
            <TextBox x:Name="CodeBox"
                     AcceptsReturn="True"
                     AcceptsTab="True"
                     TextWrapping="NoWrap"
                     FontFamily="Consolas"
                     FontSize="13"
                     Background="#FF1E1E1E"
                     Foreground="#FFD4D4D4"
                     CaretBrush="#FFD4D4D4"
                     SelectionBrush="#FF264F78"
                     BorderThickness="0"
                     Padding="4,4,0,4"
                     HorizontalScrollBarVisibility="Auto"
                     VerticalScrollBarVisibility="Auto"
                     Text="{Binding SourceText, UpdateSourceTrigger=PropertyChanged}" />
            <Canvas x:Name="IndentCanvas" IsHitTestVisible="False" ClipToBounds="True" />
          </Grid>
        </Grid>
      </Grid>

      <GridSplitter Grid.Row="1"
                    Height="4"
                    HorizontalAlignment="Stretch"
                    Background="#FF3F3F46"
                    ShowsPreview="True" />

      <!-- Console: live diagnostics for the open file -->
      <Grid Grid.Row="2" Background="#FF1E1E1E">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Background="#FF252526" LastChildFill="False">
          <TextBlock DockPanel.Dock="Left"
                     Margin="10,4"
                     Foreground="#FFCCCCCC"
                     FontWeight="SemiBold"
                     Text="CONSOLE" />
          <TextBlock DockPanel.Dock="Right"
                     Margin="10,4"
                     Foreground="#FF9CDCFE"
                     Text="{Binding ProblemSummary}" />
        </DockPanel>

        <ListBox x:Name="ProblemsList"
                 Grid.Row="1"
                 ItemsSource="{Binding Problems}"
                 MouseDoubleClick="OnProblemActivated"
                 Background="#FF1E1E1E"
                 Foreground="#FFD4D4D4"
                 BorderThickness="0"
                 FontFamily="Consolas"
                 FontSize="12"
                 ScrollViewer.HorizontalScrollBarVisibility="Auto">
          <ListBox.ItemContainerStyle>
            <Style TargetType="ListBoxItem">
              <Setter Property="Background" Value="Transparent" />
              <Setter Property="Padding" Value="6,1" />
            </Style>
          </ListBox.ItemContainerStyle>
          <ListBox.ItemTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding Display}" ToolTip="{Binding Tooltip}">
                <TextBlock.Style>
                  <Style TargetType="TextBlock">
                    <Setter Property="Foreground" Value="#FF9CDCFE" />
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding Severity}" Value="Warning">
                        <Setter Property="Foreground" Value="#FFDCDCAA" />
                      </DataTrigger>
                      <DataTrigger Binding="{Binding Severity}" Value="Error">
                        <Setter Property="Foreground" Value="#FFF48771" />
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </TextBlock.Style>
              </TextBlock>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Grid>
    </Grid>
  </DockPanel>
</Window>
