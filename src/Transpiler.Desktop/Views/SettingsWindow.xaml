<Window x:Class="Transpiler.Desktop.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Transpiler.Desktop.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:SettingsViewModel, IsDesignTimeCreatable=False}"
        Title="Settings"
        Width="500"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="130" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <!-- Languages folder -->
    <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,8,10" VerticalAlignment="Center" Text="Languages folder" />
    <DockPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,10">
      <Button DockPanel.Dock="Right"
              Margin="6,0,0,0"
              Padding="10,4"
              Content="Browse…"
              Command="{Binding BrowseLanguagesFolderCommand}" />
      <TextBox VerticalContentAlignment="Center"
               Text="{Binding LanguagesFolder, UpdateSourceTrigger=PropertyChanged}"
               ToolTip="Language files (one JSON per language: recipe, keywords, capabilities, mappings). Relative paths resolve against the application folder" />
    </DockPanel>

    <!-- Source language -->
    <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,8,10" VerticalAlignment="Center" Text="Source language" />
    <ComboBox Grid.Row="1" Grid.Column="1" Margin="0,0,0,10"
              ItemsSource="{Binding Languages}"
              SelectedItem="{Binding SourceLanguage}"
              ToolTip="The language of the files you transpile" />

    <!-- Target language -->
    <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,8,10" VerticalAlignment="Center" Text="Target language" />
    <ComboBox Grid.Row="2" Grid.Column="1" Margin="0,0,0,10"
              ItemsSource="{Binding Languages}"
              SelectedItem="{Binding TargetLanguage}"
              ToolTip="The language the output is written in" />

    <!-- Output behaviour -->
    <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,0,8,10" VerticalAlignment="Top" Text="Output" />
    <StackPanel Grid.Row="3" Grid.Column="1" Margin="0,0,0,10">
      <CheckBox Margin="0,2" Content="Overwrite existing output files" IsChecked="{Binding OverwriteExisting}" />
      <CheckBox Margin="0,2" Content="Create a .bak backup before overwriting" IsChecked="{Binding CreateBackup}" />
    </StackPanel>

    <!-- Verbosity -->
    <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,0,8,10" VerticalAlignment="Center" Text="Console verbosity" />
    <ComboBox Grid.Row="4" Grid.Column="1" Margin="0,0,0,10"
              ItemsSource="{Binding Verbosities}"
              DisplayMemberPath="Label"
              SelectedValuePath="Value"
              SelectedValue="{Binding Verbosity}" />

    <!-- Validation + buttons -->
    <StackPanel Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2">
      <TextBlock Margin="0,0,0,8"
                 Foreground="#FFCC2222"
                 Text="{Binding ValidationMessage}"
                 TextWrapping="Wrap" />
      <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
        <Button Width="90" Margin="0,0,8,0" Padding="0,6" Content="Save" IsDefault="True" Click="OnSaveClicked" />
        <Button Width="90" Padding="0,6" Content="Cancel" IsCancel="True" />
      </StackPanel>
    </StackPanel>
  </Grid>
</Window>
